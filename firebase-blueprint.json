{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Registered congregation members details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique member identifier" },
        "name": { "type": "string", "description": "Full name of the member" },
        "role": { "type": "string", "description": "Role inside the local assembly" },
        "email": { "type": "string", "format": "email", "description": "Electronic mail address" },
        "phone": { "type": "string", "description": "Primary phone contact" },
        "demographic": { "type": "string", "enum": ["Children", "Youth", "Adult", "Men", "Women"], "description": "Congregation age/gender group" },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Activity status within parish" },
        "joinedAt": { "type": "string", "description": "Registration audit logs date" },
        "notes": { "type": "string", "description": "Additional pastoral/counseling notes" }
      },
      "required": ["id", "name", "role", "email", "status"]
    },
    "NewComer": {
      "title": "NewComer",
      "description": "First-time visitors and follow up records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "firstVisit": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Attending", "Converted", "Member"] },
        "followUpNotes": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "Worship service attendance headcount logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "serviceType": { "type": "string" },
        "attendanceCount": { "type": "integer" },
        "newVisitors": { "type": "integer" }
      },
      "required": ["id", "date", "serviceType", "attendanceCount"]
    },
    "SpecialEvent": {
      "title": "SpecialEvent",
      "description": "Church Crusades, Conclaves, Conferences checklist and details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Crusade", "Retreat", "Conference", "Seminar", "Concert"] },
        "date": { "type": "string" },
        "venue": { "type": "string" },
        "budget": { "type": "integer" },
        "expectedAttendance": { "type": "integer" },
        "flyerUrl": { "type": "string" },
        "notes": { "type": "string" },
        "salvations": { "type": "integer" }
      },
      "required": ["id", "name", "type", "date"]
    },
    "VideoLink": {
      "title": "VideoLink",
      "description": "Expository sermon recording links or outreach streams",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string", "enum": ["Sermon", "Worship", "Outreach", "Seminar"] },
        "uploadedAt": { "type": "string" }
      },
      "required": ["id", "title", "url", "category"]
    },
    "SentEmail": {
      "title": "SentEmail",
      "description": "Automated email outbox campaigns",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "sentAt": { "type": "string" },
        "status": { "type": "string", "enum": ["Sent", "Scheduled", "Draft"] }
      },
      "required": ["id", "to", "subject", "body", "sentAt", "status"]
    }
  },
  "firestore": {
    "members": {
      "schema": "Member",
      "description": "Collection of church membership directory records"
    },
    "newcomers": {
      "schema": "NewComer",
      "description": "Collection of visitor cards and follow-up activities"
    },
    "attendance": {
      "schema": "AttendanceRecord",
      "description": "Collection of attendance headcount statistics"
    },
    "events": {
      "schema": "SpecialEvent",
      "description": "Collection of parish campaigns and crusades"
    },
    "videos": {
      "schema": "VideoLink",
      "description": "Collection of media links and uploaded stream recordings"
    },
    "emails": {
      "schema": "SentEmail",
      "description": "Collection of sent evangelical mail communications"
    }
  }
}
